<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:focusableInTouchMode="true"
    android:focusable="true"
    android:layout_height="match_parent">

    <!-- MAIN -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- MAP -->
        <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!--  TOP BAR (FIXED ATTRIBUTE ORDER ONLY) -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="?attr/actionBarSize"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_pill_ripple"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/menuBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#000000"/>

            <EditText
                android:id="@+id/searchBox"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search location"
                android:background="@android:color/transparent"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:imeOptions="actionSearch"
                android:inputType="text"/>

            <ImageView
                android:id="@+id/searchIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#000000"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/analyticsCard"
            android:layout_width="220dp"
            android:alpha="0.95"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_toStartOf="@id/zoomControls"
            android:layout_marginBottom="120dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_menu_active"
            android:elevation="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Movement Analysis"
                android:textStyle="bold"
                android:textColor="#222222"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/txtMovementInsight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="No active tracking"
                android:textColor="@android:color/white"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- ZOOM CONTROLS -->
        <LinearLayout
            android:id="@+id/zoomControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="100dp">

            <ImageButton
                android:id="@+id/btnZoomIn"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_circle_ripple"
                android:padding="12dp"
                android:src="@android:drawable/ic_input_add"
                android:elevation="8dp"
                android:scaleType="center"
                android:tint="#000000"/>

            <ImageButton
                android:id="@+id/btnZoomOut"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_circle_ripple"
                android:padding="12dp"
                android:src="@drawable/ic_zoom_out"
                android:elevation="8dp"
                android:scaleType="center"
                android:tint="#000000"/>
        </LinearLayout>

        <!-- MY LOCATION -->
        <ImageButton
            android:id="@+id/btnMyLocation"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_alignParentEnd="true"
            android:layout_above="@id/zoomControls"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_circle_ripple"
            android:padding="12dp"
            android:elevation="8dp"
            android:scaleType="center"
            android:tint="#000000"
            android:src="@android:drawable/ic_menu_mylocation"/>

    </RelativeLayout>

    <!-- DRAWER -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FAFAFA">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp"
            android:background="#6C4AB6">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CareTrack"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device Connected"
                android:textColor="#E0FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- MENU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:layout_gravity="top">

            <!-- ALL BUTTONS (UNCHANGED) -->

            <LinearLayout
                android:id="@+id/btnTrack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_menu_ripple"
                android:clickable="true"
                android:focusable="true"
                >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="#6C4AB6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track Device"

                    android:textSize="16sp"

                    android:textColor="#6C4AB6"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple"
                >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share Location"

                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAllowTracking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple"
                android:paddingEnd="16dp"
                >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="#666"/>

                <!-- ✅ ONLY FIX: ID added -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtAllowTracking"
                    android:text="Allow Tracking"

                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStopTrackingRemote"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple"
                android:paddingEnd="16dp"
               >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stop Tracking (Remote)"
                    android:textSize="16sp"
                    android:textColor="#222"

                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btnDrawRoute"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_directions"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Draw Route"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btnClearMarkers"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear All Markers"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btnClearRoute"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple"
               >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_directions"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear Route"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnEditName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_ripple"
                android:paddingEnd="16dp"
               >

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="#666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Device Name"
                    android:textSize="16sp"
                    android:textColor="#222"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
